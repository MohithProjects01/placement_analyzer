# AI_API_KEY: Required for AI Intelligence Engine calls.
# The platform automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the platform UI.
GEMINI_API_KEY="MY_AI_API_KEY"

# APP_URL: The URL where this app is hosted.
# The platform automatically injects this at runtime with the service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_API_URL: The base URL of your backend (e.g. Render URL)
# Needed if hosting frontend (Netlify) and backend (Render) separately.
VITE_API_URL=""
